# Blazly – Unified config (client + server)
# Copy to .env and fill in your values

# Server
PORT=4000
NODE_ENV=development

# Vercel: FRONTEND_URL = deployment URL (e.g. https://yourapp.vercel.app)
# Vercel Cron: CRON_SECRET secures cron endpoints (Vercel auto-injects for crons)

# Firebase/Firestore (required - database)
# Option 1: Path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# Option 2: Or paste JSON as string (for serverless)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Frontend URL – for OAuth redirect and CORS
# Dev: https://social.blazly.ai (Vite). Production: https://yourapp.com
FRONTEND_URL=https://social.blazly.ai

# LinkedIn
LINKEDIN_CLIENT_ID=86swiutwriegdi
LINKEDIN_CLIENT_SECRET=your_client_secret
LINKEDIN_REDIRECT_URI=https://social.blazly.ai/api/auth/linkedin/callback

# Instagram
INSTAGRAM_LOGIN_APP_ID=your_app_id
INSTAGRAM_LOGIN_APP_SECRET=your_app_secret
INSTAGRAM_REDIRECT_URI=https://social.blazly.ai/api/auth/integrations/instagram/callback

# Session
SESSION_SECRET=your_session_secret

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# Image URLs – for platforms that fetch images
API_PUBLIC_URL=
UPLOAD_BASE_URL=

# Firebase (optional – for client)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
