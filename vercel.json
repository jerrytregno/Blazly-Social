{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/scheduled-posts",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/trend-poll",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/keyword-poll",
      "schedule": "0 * * * *"
    }
  ]
}
