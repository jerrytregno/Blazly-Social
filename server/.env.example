# Server
PORT=4000
NODE_ENV=development

# Firebase/Firestore (required)
# Path to service account JSON from Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Frontend URL (for OAuth redirect and CORS)
FRONTEND_URL=http://social.blazly.ai

# LinkedIn Developer App (Blazly Social Media Automation)
# Products needed: "Share on LinkedIn" + "Sign In with LinkedIn using OpenID Connect" (for member id / profile)
# Get Client Secret from https://www.linkedin.com/developers/apps → Your app → Auth
LINKEDIN_CLIENT_ID=86swiutwriegdi
LINKEDIN_CLIENT_SECRET=your_client_secret_here
# Use frontend URL so the callback is proxied and the session cookie is set for the app (required for local dev)
# Add this exact URL in LinkedIn Developer Portal → Auth → Redirect URLs
LINKEDIN_REDIRECT_URI=http://social.blazly.ai/api/auth/linkedin/callback

# Rate limits (per 24h UTC) – tune after checking Analytics in Developer Portal
LINKEDIN_APP_DAILY_LIMIT=100
LINKEDIN_USER_DAILY_LIMIT=15

# Instagram Direct Login (Instagram API - professional accounts)
# Add this EXACT redirect URI to Meta App: Instagram product > Valid OAuth Redirect URIs
INSTAGRAM_LOGIN_APP_ID=your_app_id
INSTAGRAM_LOGIN_APP_SECRET=your_app_secret
# Must match Meta App config exactly. Backend URL avoids session/cookie issues.
INSTAGRAM_REDIRECT_URI=http://localhost:4000/api/auth/integrations/instagram/callback

# Session secret (use a long random string in production)
SESSION_SECRET=your_session_secret_here

# Gemini API (content generation + image keyword for fallback)
GEMINI_API_KEY=your_gemini_api_key

# Image URLs – Instagram/LinkedIn require publicly reachable URLs
# API_PUBLIC_URL = API base (e.g. https://yourapp.com or https://xxx.ngrok.io for local dev)
# UPLOAD_BASE_URL = full URL to uploads (S3: https://bucket.s3.../uploads, Firebase: https://...)
API_PUBLIC_URL=
UPLOAD_BASE_URL=
